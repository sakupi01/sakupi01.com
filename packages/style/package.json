{
  "name": "@sakupi01/style",
  "version": "0.0.0",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "main": "src/index.ts",
  "exports": {
    ".": "./src/css/index.css",
    "./index.css": "./src/css/index.css",
    "./layer.css": "./src/css/layer.css",
    "./sakupi01.com.css": "./src/sakupi01.com/index.css",
    "./sakupi01.com.markdown.css": "./src/sakupi01.com/markdown.css"
  },
  "type": "module",
  "scripts": {
    "check": "pnpm run check:typecheck && pnpm check:lint && pnpm check:format && pnpm run check:style",
    "check:format": "prettier --check .",
    "check:lint": "eslint .",
    "check:typecheck": "tsc --noEmit",
    "check:style": "stylelint 'src/**/*.css'",
    "fix:format": "prettier --write .",
    "fix:lint": "eslint --fix .",
    "storybook": "storybook dev -p 6006 $VITE_STORYBOOK=true",
    "build:ui": "storybook build -o ./storybook-static && node transfer.js",
    "gen": "turbo gen react-component",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@sakupi01/typescript-config": "workspace:*",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/addon-mdx-gfm": "8.6.14",
    "@storybook/addon-onboarding": "8.6.14",
    "@storybook/blocks": "8.6.14",
    "@storybook/manager-api": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "8.6.14",
    "@storybook/theming": "8.6.14",
    "@turbo/gen": "2.9.16",
    "@types/node": "20.17.17",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "prettier": "^3.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "8.6.17",
    "stylelint": "16.14.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "37.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-logical-css": "^2.1.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "5.4.5",
    "vite": "6.4.3"
  },
  "dependencies": {
    "blocks": "link:@storybook/addon-docs/blocks"
  }
}
