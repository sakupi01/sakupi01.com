---
import { Image } from "astro:assets";
import sakupiIcon from "../assets/icon.svg";

interface Props {
  href?: string;
}

const { href = "/" } = Astro.props;
---

<div class="logo">
  <a href={href}>
    <Image src={sakupiIcon} alt="logo" />
  </a>
</div>

<style>
  .logo {
    aspect-ratio: 1 / 1;
    inline-size: var(--s-icon-size-lg);

    a {
      transition: filter 0.2s;

      @media (hover: hover) {
        &:hover {
          filter: brightness(1.1);
        }
      }
    }
  }
</style>
