---
import Logo from "./Logo.astro";
import SoundIcon from "./SoundIcon.astro";
import ThemeIcon from "./ThemeIcon.astro";

interface Props {
  logoHref?: string;
}

const { logoHref = "/" } = Astro.props;
---

<header>
  <div class="left">
    <Logo href={logoHref} />
  </div>
  <div class="right">
    <slot name="navigation" />
    <ThemeIcon />
    <SoundIcon />
  </div>
</header>

<style>
  header {
    --anchor-name: --header-anchor;

    container: header / inline-size;

    .left {
      grid-column: 1;
    }

    .right {
      align-items: center;
      display: grid;
      gap: var(--s-space-gap-xs);
      grid-column: 3;
      grid-template-columns: 1fr repeat(2, auto);
    }
  }
</style>
