---
import Logo from "./Logo.astro";
import SoundIcon from "./SoundIcon.astro";
import ThemeIcon from "./ThemeIcon.astro";

interface Props {
  logoHref?: string;
}

const { logoHref = "/" } = Astro.props;
---

<header>
  <div class="left">
    <Logo href={logoHref} />
  </div>
  <div class="right">
    <slot name="navigation" />
    <ThemeIcon />
    <SoundIcon />
  </div>
</header>
