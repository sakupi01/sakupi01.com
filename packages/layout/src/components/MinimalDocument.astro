---
import type { SiteConfig } from "../types/site";
import Head from "./Head.astro";

export interface Props {
  site: SiteConfig;
  pageTitle?: string;
  description?: string;
  type?: "website" | "article";
  /** e.g. `page` for the main shell grid; omit for bare documents (404, etc.) */
  bodyClass?: string;
}

const {
  site,
  pageTitle = "Home",
  description = site.description,
  type = "website",
  bodyClass,
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <Head site={site} title={pageTitle} description={description} type={type}>
      <slot name="head-scripts" slot="scripts" />
    </Head>
    <slot name="head-append" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
