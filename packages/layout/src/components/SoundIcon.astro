<div class="megaphone-container">
  <button
    id="soundToggle"
    class="sound-toggle"
    type="button"
    title="Toggle sound"
    aria-label="Toggle sound"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="megaphone"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path
        class="megaphone-body"
        d="M10,7L15,2L16,3V21L15,22L10,17H6C4.9,17 4,16.1 4,15V9C4,7.9 4.9,7 6,7H10Z"
      ></path>

      <path
        class="sound-wave sound-wave-outer"
        d="M 20.0703 4.92999 C 21.945 6.80527 22.9982 9.34835 22.9982 12 C 22.9982 14.6516 21.945 17.1947 20.0703 19.07"
        stroke-linecap="round"
        stroke-linejoin="round"></path>

      <path
        class="sound-wave sound-wave-inner"
        d="M 17.54 8.46002 C 18.4774 9.39766 19.004 10.6692 19.004 11.995 C 19.004 13.3208 18.4774 14.5924 17.54 15.53"
        stroke-linecap="round"
        stroke-linejoin="round"></path>

      <line
        x1="3"
        y1="21"
        x2="21"
        y2="3"
        class="mute-line"
        stroke-linecap="round"></line>
    </svg>

    <svg
      class="ripples"
      viewBox="0 0 100 100"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle class="ripple ripple-1" cx="50" cy="50" r="45"></circle>
      <circle class="ripple ripple-2" cx="50" cy="50" r="45"></circle>
      <circle class="ripple ripple-3" cx="50" cy="50" r="45"></circle>
    </svg>
  </button>
</div>

<style>
  .megaphone-container {
    --bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
    --wave-transition:
      opacity 300ms ease,
      transform 390ms var(--bounce);

    block-size: var(--s-icon-size-sm);
    inline-size: var(--s-icon-size-sm);

    @media (width <= 768px) {
      display: none;
    }
  }

  .sound-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    position: relative;
    transition: transform 0.3s var(--bounce);

    @media (hover: hover) {
      &:hover {
        transform: scale(1.1);
      }
    }

    &:active {
      transform: scale(0.95);
    }

    & .megaphone {
      block-size: 100%;
      fill: none;
      inline-size: 100%;
      stroke: currentColor;
      stroke-width: 1.5;
    }

    & .megaphone-body {
      fill: currentColor;
      transform-origin: center;
      transition: transform 600ms var(--bounce);
    }

    & .sound-wave {
      opacity: 1;
      stroke: var(--s-color-primary);
      stroke-width: 1.5;
      transform-origin: center left;
      transition: var(--wave-transition);

      &.sound-wave-outer {
        transition-delay: 150ms;
      }
    }

    & .mute-line {
      opacity: 0;
      stroke: var(--s-color-primary);
      stroke-width: 1.5;
      transform: scale(0);
      transform-origin: center;
      transition: var(--wave-transition);
    }

    & .ripples {
      block-size: 100%;
      inline-size: 100%;
      inset-block-start: 0;
      inset-inline-start: 0;
      pointer-events: none;
      position: absolute;
      z-index: 1;
    }

    & .ripple {
      fill: none;
      opacity: 0;
      stroke: var(--s-color-primary);
      stroke-width: 1;
      transform-origin: center;
    }

    &.sound-toggle--toggled {
      & .sound-wave {
        opacity: 0;
        transform: scale(0);
      }

      & .mute-line {
        opacity: 1;
        transform: scale(1);
      }

      & .megaphone-body {
        transform: scale(0.95);
      }
    }

    &.animate-click {
      & .megaphone {
        animation: shake 0.6s ease-in-out;
      }

      & .ripple-1 {
        animation: ripple 1.2s ease-out;
      }

      & .ripple-2 {
        animation: ripple 1.2s ease-out 0.2s;
      }

      & .ripple-3 {
        animation: ripple 1.2s ease-out 0.4s;
      }
    }
  }

  @keyframes shake {
    0%,
    100% {
      transform: rotate(0deg);
    }

    25% {
      transform: rotate(-5deg);
    }

    75% {
      transform: rotate(5deg);
    }
  }

  @keyframes ripple {
    0% {
      opacity: 0.7;
      r: 10;
      stroke-width: 2;
    }

    100% {
      opacity: 0;
      r: 45;
      stroke-width: 0.5;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const soundToggle = document.getElementById("soundToggle");
    if (!soundToggle) return;

    const MOBILE_QUERY = "(max-width: 768px)";
    const STORAGE_KEY = "soundEnabled";

    const isMobile = (): boolean => window.matchMedia(MOBILE_QUERY).matches;

    const getSoundPreference = (): boolean => {
      if (isMobile()) return false;
      const stored = localStorage.getItem(STORAGE_KEY);
      return stored === null ? true : stored === "true";
    };

    const setSoundState = (soundOn: boolean): void => {
      localStorage.setItem(STORAGE_KEY, String(soundOn));
      soundToggle.classList.toggle("sound-toggle--toggled", !soundOn);
      soundToggle.setAttribute(
        "aria-label",
        soundOn
          ? "Sound is on. Click to turn off."
          : "Sound is off. Click to turn on."
      );
    };

    setSoundState(getSoundPreference());

    const soundOnAudio = new Audio("/sounds/sound-on.mp3");
    const soundOffAudio = new Audio("/sounds/sound-off.mp3");
    for (const audio of [soundOnAudio, soundOffAudio]) {
      audio.volume = 0.4;
      audio.preload = "auto";
    }

    const playClickAnimation = (): void => {
      soundToggle.classList.add("animate-click");
      setTimeout(() => soundToggle.classList.remove("animate-click"), 1200);
    };

    soundToggle.addEventListener("click", () => {
      const willBeOn = soundToggle.classList.contains("sound-toggle--toggled");

      playClickAnimation();

      const audio = willBeOn ? soundOnAudio : soundOffAudio;
      audio.play().catch((e: Error) => console.warn("Failed to play sound: ", e));

      setSoundState(willBeOn);
    });
  });
</script>
