---
import type { SiteConfig } from "../types/site";
import MinimalDocument from "./MinimalDocument.astro";

export interface Props {
  site: SiteConfig;
  pageTitle?: string;
  description?: string;
  type?: "website" | "article";
}

const {
  site,
  pageTitle = "Home",
  description = site.description,
  type = "website",
} = Astro.props;
---

<MinimalDocument
  site={site}
  pageTitle={pageTitle}
  description={description}
  type={type}
  bodyClass="page"
>
  <slot name="head-scripts" slot="head-scripts" />
  <Fragment slot="head-append">
    <!-- Polyfills -->
    <script type="module">
      if (!("anchorName" in document.documentElement.style)) {
        import("https://unpkg.com/@oddbird/css-anchor-positioning");
      }
    </script>

    <!-- Other Site Scripts -->
    <script>
      import { setupThemeToggle } from "@sakupi01/layout";
      setupThemeToggle();

      console.log("O HAI THERE !🌸 - @blog.sakupi01.com");
    </script>
    <slot name="head-extra" />
  </Fragment>
  <slot />
</MinimalDocument>
