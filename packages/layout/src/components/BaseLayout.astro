---
import type { SiteConfig } from "../types/site";
import Head from "./Head.astro";

export interface Props {
  site: SiteConfig;
  pageTitle?: string;
  description?: string;
  type?: "website" | "article";
}

const {
  site,
  pageTitle = "Home",
  description = site.description,
  type = "website",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <Head site={site} title={pageTitle} description={description} type={type}>
      <slot name="head-scripts" slot="scripts" />
    </Head>

    <!-- Polyfills -->
    <script type="module">
      if (!("anchorName" in document.documentElement.style)) {
        import("https://unpkg.com/@oddbird/css-anchor-positioning");
      }
    </script>

    <!-- Other Site Scripts -->
    <script>
      import { setupThemeToggle } from "@sakupi01/layout";
      setupThemeToggle();

      console.log("O HAI THERE !🌸 - @blog.sakupi01.com");
    </script>
    <slot name="head-extra" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="page">
    <slot />
  </body>
</html>
