---
import type { SlideItem } from "../data/slides";
import { fetchSlides, formatRFC2822Date } from "../data/slides";

const slides = await fetchSlides();
---

<div class="carousel-container">
  {
    slides.length === 0 ? (
      <div class="loading-indicator">Slide Not Found...</div>
    ) : (
      <ul
        class="carousel"
        data-anchor-name="--slides-carousel"
        aria-label="Slides Carousel"
        aria-live="polite"
      >
        {slides.map((slide: SlideItem) => (
          <li class="carousel-item">
            <a href={slide.url} class="slide-card">
              <figure>
                <figcaption>
                  <h3>{slide.title}</h3>
                  {slide.description && <p>{slide.description}</p>}
                </figcaption>
                {slide.thumbnail ? (
                  <img
                    src={slide.thumbnail}
                    alt={slide.title}
                    class="slide-thumbnail frame"
                  />
                ) : (
                  <div class="slide-thumbnail-placeholder frame">
                    {slide.title.charAt(0)}
                  </div>
                )}
                <p class="slide-date">{formatRFC2822Date(slide.pubDate)}</p>
                {slide.tags.length > 0 && (
                  <div class="slide-tags">
                    {slide.tags.map((tag: string) => (
                      <span class="slide-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </figure>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</div>

<style>
  /* -----------------------------------------------------------------------
        Carousel
        ----------------------------------------------------------------------- */
  .carousel-container {
    container: carousel / inline-size;
    margin: var(--s-space-layout-lg) 0;
  }

  .carousel {
    --anchor-name: attr(
      data-anchor-name type(<custom-ident>),
      --slides-carousel
    );

    anchor-name: var(--anchor-name);
    anchor-scope: var(--anchor-name);
    display: grid;
    gap: var(--s-space-layout-md);
    grid-auto-columns: 70cqi;
    grid-auto-flow: column;
    inline-size: 100cqi;
    list-style-type: "";
    margin: 0;
    overflow-inline: auto;
    overscroll-behavior-inline: contain;
    padding: 0;
    padding-block: var(--s-space-layout-2xs);
    scroll-behavior: smooth;
    scroll-marker-group: after;
    scroll-padding-inline: 5vmin;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;

    &::scroll-marker-group {
      display: grid;
      grid-auto-columns: var(--s-space-gutter-sm);
      grid-auto-flow: column;
      position: fixed;
      position-anchor: attr(
        data-anchor-name type(<custom-ident>),
        --slides-carousel
      );
      position-area: block-end;
    }

    &::scroll-button(*) {
      align-items: center;
      aspect-ratio: 1 / 1;
      background-color: transparent;
      border-radius: var(--s-border-radius-full);
      border-width: 0;
      cursor: pointer;
      display: flex;
      flex-wrap: nowrap;
      inline-size: var(--s-icon-size-xl);
      justify-content: center;
      position: absolute;
      position-anchor: var(--anchor-name);
    }

    @media (hover: hover) {
      &::scroll-button(*):hover {
        background: var(--s-color-surface-raised);
      }
    }

    &::scroll-button(*):disabled {
      background: transparent;
      cursor: default;
      opacity: 0.3;
    }

    &::scroll-button(left) {
      content: var(--image-arrow-left) / "Scroll Left";
      position-area: left center;
    }

    &::scroll-button(right) {
      content: var(--image-arrow-right) / "Scroll Right";
      position-area: right center;
    }
  }

  /* -----------------------------------------------------------------------
     Carousel item
     ----------------------------------------------------------------------- */

  .carousel-item {
    container: snap-container / scroll-state;
    scroll-snap-align: center;

    /* -----------------------------------------------------------------------
       Slide card
       ----------------------------------------------------------------------- */

    .slide-card {
      --gradPoint: 0%;

      background-clip: text;
      background-image: var(--card-gradient);
      background-repeat: no-repeat;
      border-radius: var(--s-border-radius-lg);
      color: var(--s-color-text-primary);
      color: transparent;
      cursor: pointer;
      display: flex;
      font-weight: var(--s-font-weight-semibold);
      interactivity: inert;
      justify-content: center;
      opacity: 0.6;
      padding: var(--s-space-layout-2xs);
      scale: 0.95;
      transition:
        filter 0.8s,
        opacity 0.3s,
        scale 0.3s;

      & figure {
        display: flex;
        flex-direction: column;
        gap: var(--s-space-gap-3xs);
        margin: 0;

        & figcaption .slide-meta {
          display: flex;
          flex-direction: column;
        }

        & h3 {
          font-size: var(--s-font-size-h3);
          margin: var(--s-space-gutter-2xs) 0;
        }

        & p {
          -webkit-box-orient: vertical;
          color: inherit;
          display: -webkit-box;
          font-size: var(--s-font-size-sm);
          -webkit-line-clamp: 2;
          line-height: var(--s-line-height-base);
          margin: var(--s-space-gutter-2xs) 0;
          overflow: hidden;
        }
      }
    }

    @container snap-container scroll-state(snapped: inline) {
      .slide-card {
        interactivity: auto;
        opacity: 1;
        scale: 1;
      }
    }

    &::scroll-marker {
      color: var(--s-color-text-primary);
      content: var(--image-bullet-list) "  ";
      cursor: pointer;
      transition: scale 0.3s ease-in-out;
    }

    &:nth-child(3n)::scroll-marker {
      color: var(--s-color-text-primary);
      content: var(--image-bullet-list-2) "  ";
      transition: scale 0.3s ease-in-out;
    }

    &:nth-child(3n - 1)::scroll-marker {
      color: var(--s-color-text-primary);
      content: var(--image-bullet-list-3) "  ";
      transition: scale 0.3s ease-in-out;
    }

    &::scroll-marker:target-current {
      color: var(--s-color-link);
      scale: 1.5;
    }

    /* --- gradient colors per card --- */
    &:nth-child(6n + 1) > .slide-card {
      /* stylelint-disable-next-line custom/token-scope */
      --card-gradient: linear-gradient(
        var(--p-color-orange-400) var(--gradPoint),
        var(--p-color-red-500) calc(var(--gradPoint) + 20%)
      );

      animation:
        hue-drift-orange-red 2s infinite alternate ease-in-out,
        grad-slide 2s infinite alternate ease-in-out;
    }

    &:nth-child(6n + 2) > .slide-card {
      /* stylelint-disable-next-line custom/token-scope */
      --card-gradient: linear-gradient(
        var(--p-color-turquoise-400) var(--gradPoint),
        var(--p-color-green-500) calc(var(--gradPoint) + 20%)
      );

      animation:
        hue-drift-turquoise-green 2s infinite alternate ease-in-out,
        grad-slide 2s infinite alternate ease-in-out;
    }

    &:nth-child(6n + 3) > .slide-card {
      /* stylelint-disable-next-line custom/token-scope */
      --card-gradient: linear-gradient(
        var(--p-color-lavender-400) var(--gradPoint),
        var(--p-color-azure-500) calc(var(--gradPoint) + 20%)
      );

      animation:
        hue-drift-lavender-azure 2s infinite alternate ease-in-out,
        grad-slide 2s infinite alternate ease-in-out;
    }

    &:nth-child(6n + 4) > .slide-card {
      /* stylelint-disable-next-line custom/token-scope */
      --card-gradient: linear-gradient(
        var(--p-color-mustard-400) var(--gradPoint),
        var(--p-color-orange-600) calc(var(--gradPoint) + 20%)
      );

      animation:
        hue-drift-mustard 2s infinite alternate ease-in-out,
        grad-slide 2s infinite alternate ease-in-out;
    }

    &:nth-child(6n + 5) > .slide-card {
      /* stylelint-disable-next-line custom/token-scope */
      --card-gradient: linear-gradient(
        var(--p-color-fuchsia-400) var(--gradPoint),
        var(--p-color-flamingo-500) calc(var(--gradPoint) + 20%)
      );

      animation:
        hue-drift-fuchsia-flamingo 2s infinite alternate ease-in-out,
        grad-slide 2s infinite alternate ease-in-out;
    }

    &:nth-child(6n) > .slide-card {
      /* stylelint-disable-next-line custom/token-scope */
      --card-gradient: linear-gradient(
        var(--p-color-pelorus-400) var(--gradPoint),
        var(--p-color-turquoise-600) calc(var(--gradPoint) + 20%)
      );

      animation:
        hue-drift-pelorus 2s infinite alternate ease-in-out,
        grad-slide 2s infinite alternate ease-in-out;
    }
  }

  @supports (background-clip: border-area) {
    .slide-card {
      background-clip: padding-box, border-area, text;
      background-image:
        var(--card-gradient), var(--card-gradient), var(--card-gradient);
      background-origin: border-box;
      background-repeat: no-repeat;
      border: var(--s-border-width-base) solid transparent;
      color: transparent;
      /* stylelint-disable-next-line custom/token-scope */
      padding: calc(var(--s-space-layout-md) - var(--s-border-width-base));
      text-shadow: none;
    }
  }

  /* -----------------------------------------------------------------------
     @property registration for smooth animation
     ----------------------------------------------------------------------- */

  @property --gradPoint {
    inherits: false;
    initial-value: 0%;
    syntax: "<percentage>";
  }

  /* -----------------------------------------------------------------------
     @keyframes registration
     ----------------------------------------------------------------------- */

  @keyframes grad-slide {
    from {
      --gradPoint: 0%;
    }

    to {
      --gradPoint: 100%;
    }
  }

  @keyframes hue-drift-orange-red {
    from {
      --p-color-orange-hue: 50;
      --p-color-red-hue: 20;
    }

    to {
      --p-color-orange-hue: 65;
      --p-color-red-hue: 5;
    }
  }

  @keyframes hue-drift-turquoise-green {
    from {
      --p-color-turquoise-hue: 180;
      --p-color-green-hue: 130;
    }

    to {
      --p-color-turquoise-hue: 195;
      --p-color-green-hue: 150;
    }
  }

  @keyframes hue-drift-lavender-azure {
    from {
      --p-color-lavender-hue: 290;
      --p-color-azure-hue: 250;
    }

    to {
      --p-color-lavender-hue: 270;
      --p-color-azure-hue: 235;
    }
  }

  @keyframes hue-drift-mustard {
    from {
      --p-color-mustard-hue: 90;
      --p-color-orange-hue: 50;
    }

    to {
      --p-color-mustard-hue: 75;
      --p-color-orange-hue: 40;
    }
  }

  @keyframes hue-drift-fuchsia-flamingo {
    from {
      --p-color-fuchsia-hue: 320;
      --p-color-flamingo-hue: 360;
    }

    to {
      --p-color-fuchsia-hue: 305;
      --p-color-flamingo-hue: 345;
    }
  }

  @keyframes hue-drift-pelorus {
    from {
      --p-color-pelorus-hue: 210;
      --p-color-turquoise-hue: 180;
    }

    to {
      --p-color-pelorus-hue: 225;
      --p-color-turquoise-hue: 195;
    }
  }

  /* -----------------------------------------------------------------------
     Misc
     ----------------------------------------------------------------------- */

  .loading-indicator {
    padding: var(--s-space-layout-lg);
    text-align: center;
  }

  .slide-thumbnail {
    border-radius: var(--s-border-radius-md);
  }

  .slide-thumbnail-placeholder {
    display: grid;
    place-content: center;
  }

  .slide-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-space-layout-sm);
  }

  .slide-tag {
    border: var(--s-border-width-thin) solid var(--s-color-border-default);
    border-radius: var(--s-border-radius-full);
    font-size: var(--s-font-size-xs);
    padding: var(--s-space-layout-3xs) var(--s-space-layout-2xs);
  }

  .slide-date {
    font-size: var(--s-font-size-sm);
    font-style: italic;
    margin: var(--s-space-gutter-sm) 0;
  }
</style>
