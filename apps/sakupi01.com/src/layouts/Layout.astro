---
import "@sakupi01/style";
import "@sakupi01/style/sakupi01.com.css";
import Layout from "@sakupi01/layout/components/Layout.astro";
import Navigation from "@sakupi01/layout/components/Navigation.astro";
import { site } from "../data/site";

interface Props {
  pageTitle?: string;
  description?: string;
  url: string;
}

const {
  pageTitle = "Home",
  description = "The personal website of saku. A Front-end developer, Design Technologist, and an enthusiast of all things about Web & UI",
} = Astro.props;

// Speculation Rules: prefetch the (same-site, cross-origin) blog on
// likely-navigation signals. Same-origin documents are already handled by the
// shared Head.astro block; this rule covers blog.sakupi01.com links, which that
// rule's relative `/*` matcher cannot reach. Exclusions mirror Head.astro
// (skip new-tab links and the feed) to avoid wasteful prefetches.
const blogBase = import.meta.env.PUBLIC_BLOG ?? "https://blog.sakupi01.com/";
const blogOrigin = new URL(blogBase, Astro.url.href).origin;
const speculationRules = {
  prefetch: [
    {
      source: "document",
      where: {
        and: [
          { href_matches: `${blogOrigin}/*` },
          { not: { href_matches: `${blogOrigin}/feed.xml` } },
          { not: { selector_matches: "[target=_blank]" } },
          { not: { selector_matches: "[rel~=nofollow]" } },
        ],
      },
      eagerness: "moderate",
    },
  ],
};
---

<Layout site={site} pageTitle={pageTitle} description={description}>
  <script
    slot="head-extra"
    type="speculationrules"
    is:inline
    set:html={JSON.stringify(speculationRules)}
  />
  <Navigation slot="navigation" />
  <slot />
</Layout>
