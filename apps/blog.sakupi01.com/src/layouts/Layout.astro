---
import "@sakupi01/style";
import "@sakupi01/style/sakupi01.com.css";
import Layout from "@sakupi01/layout/components/Layout.astro";
import Navigation from "@sakupi01/layout/components/Navigation.astro";
import { site } from "../data/site";

interface Props {
  pageTitle: string;
  description: string;
  url: string;
}

const { pageTitle, description } = Astro.props;
---

<Layout
  site={site}
  pageTitle={pageTitle}
  description={description}
  logoHref={import.meta.env.PUBLIC_HOME}
  type="article"
>
  <Navigation slot="navigation" />
  <Fragment slot="head-scripts">
    <!-- External Scripts -->
    <script is:inline src="/_scripts/2025-ad-calendar.js"></script>
    <script is:inline src="/_scripts/cascade-accordion.js"></script>
    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/baseline-status@latest/baseline-status.min.js"
      type="module"></script>
    <!-- Locale-aware dates (progressive enhancement). The server renders
         dates in English to match the site's English UI; for non-English
         readers we reformat <time> to their own locale. Re-runs on every
         navigation because cross-document view transitions keep full loads. -->
    <script is:inline>
      (() => {
        const lang = navigator.language || "en";
        if (lang.toLowerCase().startsWith("en")) return;
        const fmt = new Intl.DateTimeFormat(lang, {
          year: "numeric",
          month: "long",
          day: "numeric",
          timeZone: "UTC",
        });
        const localize = () => {
          for (const el of document.querySelectorAll("time[datetime]")) {
            const d = new Date(el.getAttribute("datetime"));
            if (!Number.isNaN(d.getTime())) el.textContent = fmt.format(d);
          }
        };
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", localize);
        } else {
          localize();
        }
      })();
    </script>
  </Fragment>
  <slot />
</Layout>
