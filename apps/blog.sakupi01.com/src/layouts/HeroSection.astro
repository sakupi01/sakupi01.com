---
import Title from "@sakupi01/layout/components/Title.astro";
import {
  convertToValidTimeDateString,
  formatRFC2822Date,
} from "../utils/formatRFC2822Date";

const { title, image, date, update, excerpt } = Astro.props;
---

<div class="hero-section">
  <Title title={title} />
  {image && <img src={image} alt={title} />}
  <div class="dates">
    <p class="published">
      Published on <time datetime={convertToValidTimeDateString(date)}
        >{formatRFC2822Date(date)}</time
      >
    </p>
    <p class="update">
      Updated on <time datetime={convertToValidTimeDateString(update)}
        >{formatRFC2822Date(update)}</time
      >
    </p>
  </div>
  <p class="excerpt">{excerpt}</p>
</div>

<style>
  .hero-section {
    margin-block-end: var(--s-space-gutter-lg);
  }

  .dates {
    display: grid;
    gap: var(--s-space-gap-sm);
    grid-template-columns: auto auto 1fr;
    grid-template-rows: 1fr;
    margin-block-end: var(--s-space-gutter-sm);

    .published {
      color: var(--s-color-text-primary);
      font-weight: var(--s-font-weight-normal);
    }
  }

  .excerpt {
    margin-block: 0 var(--s-space-gutter-sm);
    text-wrap: pretty;
  }
</style>
