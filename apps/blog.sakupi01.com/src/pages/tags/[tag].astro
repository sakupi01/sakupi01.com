---
import Title from "@sakupi01/layout/components/Title.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import Layout from "../../layouts/Layout.astro";
import { allPosts } from "../../utils/contents";

export async function getStaticPaths() {
  const dynamicTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];
  return dynamicTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) =>
      post.data.tags.includes(tag)
    );
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout
  pageTitle={`Posts tagged with #${tag}`}
  description={`Posts tagged with #${tag}`}
  url={`/tags/${encodeURIComponent(tag)}/`}
>
  <Title title={`Posts tagged with #${tag} ...`} />
  <ul class="stack">
    {
      posts.map((post) => {
        const url = `${import.meta.env.PUBLIC_BLOG}${post.slug}`;
        return (
          <BlogPostCard
            url={url}
            title={post.data.title}
            date={post.data.date}
            excerpt={post.data.excerpt}
          />
        );
      })
    }
  </ul>
</Layout>

<style>
  .stack {
    --stack-gutter: var(--s-space-gutter-xl);
  }
</style>
