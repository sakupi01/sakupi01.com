---
import BlogPostCard from "../components/BlogPostCard.astro";
import Title from "@sakupi01/layout/components/Title.astro";
import Layout from "../layouts/Layout.astro";
import { allPosts } from "../utils/contents";
---

<Layout pageTitle="Archive" description="Blog Archive" url="/">
  <Title title="Archive | blog.sakupi01.com" />
  <ul class="stack">
    {
      allPosts.map((post) => {
        const url = post.data.tags.includes("zenn")
          ? `${import.meta.env.PUBLIC_ZENN_BASE_URL}${post.id}`
          : `${import.meta.env.PUBLIC_BLOG}${post.id}`;
        return (
          <BlogPostCard
            url={url}
            title={post.data.title}
            date={post.data.date}
            excerpt={post.data.excerpt}
          />
        );
      })
    }
  </ul>
</Layout>

<style>
  .stack {
    --stack-gutter: var(--s-space-gutter-xl);
  }
</style>
