---
import "@sakupi01/style/sakupi01.com.css";
import BlogPostCardForIFrame from "../../components/BlogPostCardForIFrame.astro";
import BaseLayout from "@sakupi01/layout/components/BaseLayout.astro";
import { site } from "../../data/site";
import { allPosts } from "../../utils/contents";
---

<BaseLayout
  site={site}
  pageTitle="Recent Blogs Archive"
  description="Recent Blogs Archive"
  type="article"
>
  <main>
    <ul class="posts">
      {
        allPosts.map((post) => {
          const url = post.data.tags.includes("zenn")
            ? `${import.meta.env.PUBLIC_ZENN_BASE_URL}${post.slug}`
            : `${import.meta.env.PUBLIC_BLOG}${post.slug}`;
          return (
            <BlogPostCardForIFrame
              url={url}
              title={post.data.title}
              date={post.data.date}
              excerpt={post.data.excerpt}
            />
          );
        })
      }
    </ul>
  </main>
</BaseLayout>

<style>
  .posts {
    display: grid;
    gap: 3rem;
    padding: 1rem 0;
  }
  main {
    padding: 0;
  }
</style>
