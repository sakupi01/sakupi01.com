---
import BlogPostCard from "../../../components/BlogPostCard.astro";
import Title from "@sakupi01/layout/components/Title.astro";
import Layout from "../../../layouts/Layout.astro";
import { allLifePosts } from "../../../utils/contents";
---

<Layout
  pageTitle="Life Blog Archive"
  description="Life Blog Archive"
  url="/life/"
>
  <Title title="Life Blog Archive ..." />
  <ul class="stack">
    {
      allLifePosts.map((post) => {
        const url = `${import.meta.env.PUBLIC_BLOG}${post.id}`;
        return (
          <BlogPostCard
            url={url}
            title={post.data.title}
            date={post.data.date}
            excerpt={post.data.excerpt}
          />
        );
      })
    }
  </ul>
</Layout>

<style>
  .stack {
    --stack-gutter: var(--s-space-gutter-xl);
  }
</style>
